# .env config for AWS t4g.large (8GB RAM)

# --- WEB SERVER (GUNICORN) ---
# 10 minute timeout to prevent 504 errors on big files
GUNICORN_TIMEOUT=600
# 3 Workers is ideal for 2 vCPUs (2*CPU + 1)
GUNICORN_WORKERS=3
# Limit web app RAM so it doesn't steal from the worker
WEB_MEMORY_LIMIT=1024M

# --- INGEST WORKER ---
# Give the heavy lifter the most RAM (4GB)
WORKER_MEMORY_LIMIT=4096M

# --- DATABASE ---
# Limit DB to 2GB so we have room for the worker
DB_MEMORY_LIMIT=2048M
POSTGRES_SHARED_BUFFERS=512MB

# --- SAFETY FLAGS ---
# False = Do NOT drop tables on restart (Production Safe)
FORCE_SCHEMA_REFRESH=False
